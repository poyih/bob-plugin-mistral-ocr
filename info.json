{
    "identifier": "bob-plugin-mistral-ocr",
    "version": "1.2.0",
    "category": "ocr",
    "name": "Mistral OCR",
    "summary": "使用 Mistral AI OCR 进行文本识别",
    "icon": "",
    "author": "poyih and Claude",
    "homepage": "https://github.com/poyih/bob-plugin-Mistral-ocr",
    "appcast": "https://raw.githubusercontent.com/poyih/bob-plugin-Mistral-ocr/main/appcast.json",
    "minBobVersion": "1.8.0",
    "options": [
        {
            "identifier": "apiKey",
            "type": "text",
            "title": "API Key",
            "desc": "Mistral AI API Key（获取地址: console.mistral.ai）",
            "textConfig": {
                "type": "secure",
                "placeholderText": "请输入 Mistral AI API Key"
            }
        },
        {
            "identifier": "apiUrl",
            "type": "text",
            "title": "自定义 API 地址",
            "desc": "可留空，默认为 https://api.mistral.ai",
            "textConfig": {
                "type": "visible",
                "placeholderText": "https://api.mistral.ai"
            }
        },
        {
            "identifier": "model",
            "type": "menu",
            "title": "OCR 模型",
            "desc": "选择 Mistral OCR 模型版本，默认跟随官方最新版",
            "defaultValue": "mistral-ocr-latest",
            "menuValues": [
                { "title": "最新版（推荐）", "value": "mistral-ocr-latest" },
                { "title": "OCR 3（25.12）", "value": "mistral-ocr-2512" },
                { "title": "OCR 2（25.05）", "value": "mistral-ocr-2505" },
                { "title": "OCR（25.03）", "value": "mistral-ocr-2503" }
            ]
        },
        {
            "identifier": "keepMarkdown",
            "type": "menu",
            "title": "保留 Markdown 格式",
            "desc": "Mistral OCR 返回 Markdown 格式文本，可选择是否去除格式符号",
            "defaultValue": "false",
            "menuValues": [
                { "title": "去除（纯文本）", "value": "false" },
                { "title": "保留", "value": "true" }
            ]
        }
    ]
}
